@article{Olugbemi2026Tshirt,
 abstract = {This study quantifies uncertainty in process-based carbon accounting for cradle-to-gate production of a cotton T-shirt. The total carbon footprint was estimated at 1.37 kg CO2e per T-shirt with an uncertainty of ±13.81%. Fabric production contributes the largest share of emissions and uncertainty.},
 author = {Olugbemi, Emmanuel and Favero Bolson, Natanael},
 doi = {10.1038/s41598-026-38773-4},
 journal = {Scientific Reports},
 number = {1},
 pages = {7586},
 title = {Uncertainty analysis of physical-based carbon accounting in cotton T-shirt manufacturing},
 volume = {16},
 year = {2026}
}
