@article{Bolson2026Circularity,
  title = {Material circularity in the UK's foundation industries},
  author = {Bolson, Natanael and Ahmadinia, Masoud and Setchi, Rossi and Evans, Sam and Cullen, Jonathan},
  journal = {Resources, Conservation and Recycling},
  year = {2026},
  volume = {227},
  pages = {108728},
  doi = {10.1016/j.resconrec.2025.108728},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0921344925006056},
  abstract = {This study evaluates how circular economy principles can reshape the use of aluminium, lead, steel, glass, and paper in the UK's foundation industries. Circularity strategies could reduce emissions by 42% and energy use by 17%, rising to 69% and 56% when combined with best-practice energy intensities.}
}

