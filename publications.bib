@article{FaveroBolson2026SolarEfficiency,
  title = {Empirical evidence of improvements in material and carbon efficiency of crystalline silicon solar panels},
  author = {Favero Bolson, Natanael and Iqbal, Haider},
  journal = {Materials Research Express},
  year = {2026},
  volume = {13},
  number = {5},
  pages = {055501},
  doi = {10.1088/2053-1591/ae4855},
  url = {https://iopscience.iop.org/article/10.1088/2053-1591/ae4855},
  abstract = {This study analyses changes in crystalline silicon photovoltaic module performance between 2008-2012 and 2020-2024 using specifications from 320 commercial products. The power-to-weight ratio increased from 10.5 W kg-1 to 19.1 W kg-1, while the power-to-area ratio rose from 135.3 W m-2 to 219.5 W m-2. The carbon intensity of module production declined by 72%.}
}

@article{Olugbemi2026Tshirt,
  title = {Uncertainty analysis of physical-based carbon accounting in cotton T-shirt manufacturing},
  author = {Olugbemi, Emmanuel and Favero Bolson, Natanael},
  journal = {Scientific Reports},
  year = {2026},
  volume = {16},
  number = {1},
  pages = {7586},
  doi = {10.1038/s41598-026-38773-4},
  abstract = {This study quantifies uncertainty in process-based carbon accounting for cradle-to-gate production of a cotton T-shirt. The total carbon footprint was estimated at 1.37 kg CO2e per T-shirt with an uncertainty of ±13.81%. Fabric production contributes the largest share of emissions and uncertainty.}
}

